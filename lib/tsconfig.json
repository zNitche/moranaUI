{
    "compilerOptions": {
        "target": "es2024",
        "lib": [
            "ES2024",
            "DOM"
        ],
        "module": "esnext",
        "types": [
            "node"
        ],
        "skipLibCheck": true,
        /* Bundler mode */
        "moduleResolution": "bundler",
        "verbatimModuleSyntax": true,
        "noEmit": true,
        "outDir": "dist",
        "rootDir": ".",
        "declaration": false,
        "jsx": "react-jsx",
        "paths": {
            "@root/*": [
                "./src/*"
            ]
        },
        "resolveJsonModule": true,
        "isolatedModules": true,
        /* Linting */
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "erasableSyntaxOnly": true,
        "noFallthroughCasesInSwitch": true
    },
    "include": [
        "src",
        "vite_plugins",
        "tests"
    ]
}